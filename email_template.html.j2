<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>ACR Weekly Digest — Oak Hill Advisors</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
@media only screen and (max-width: 600px) {
  .email-container { width: 100% !important; }
  .kpi-strip td { display: block !important; width: 100% !important; border-left: none !important; border-top: 3px solid !important; }
  .kpi-strip .kpi-green { border-top-color: #10b981 !important; }
  .kpi-strip .kpi-red { border-top-color: #dc2626 !important; }
  .stack-mobile { display: block !important; width: 100% !important; padding: 0 !important; }
  .pad-mobile { padding-left: 16px !important; padding-right: 16px !important; }
  .chart-img { max-width: 100% !important; height: auto !important; }
  table.data-table { font-size: 10px !important; }
  table.data-table th, table.data-table td { padding: 5px 6px !important; }
  .section-header { padding: 8px 12px !important; font-size: 11px !important; }
  .email-h1 { font-size: 18px !important; }
  .email-week { font-size: 12px !important; }
  .threshold-notice { padding: 10px 16px !important; font-size: 10px !important; }
  .narrative { padding: 16px 16px 4px !important; }
  .narrative-body { font-size: 11px !important; }
}
</style>
</head>
<body style="margin:0;padding:24px;background:#f1f5f9;font-family:-apple-system,'Segoe UI','Helvetica Neue',Arial,sans-serif;color:#0f172a">

<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" class="email-container" style="width:100%;max-width:720px;margin:0 auto;background:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(15,23,42,0.08)">

  <!-- HEADER -->
  <tr>
    <td style="background:linear-gradient(135deg,#0f172a,#1e293b);padding:28px 32px 22px;border-bottom:3px solid #fbbf24">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="vertical-align:top">
            <div style="font-size:11px;font-weight:600;letter-spacing:2px;color:#fbbf24;text-transform:uppercase;margin-bottom:4px">Oak Hill Advisors</div>
            <div class="email-h1" style="font-size:22px;font-weight:800;color:#f8fafc;letter-spacing:-0.5px;line-height:1.2">ACR Weekly Digest</div>
            <div style="font-size:12px;color:#94a3b8;margin-top:4px">Carbon credit registry activity — IFM & Non-IFM</div>
          </td>
          <td style="vertical-align:top;text-align:right;width:160px">
            <div style="font-size:10px;color:#64748b;text-transform:uppercase;letter-spacing:1px">Reporting Week</div>
            <div class="email-week" style="font-size:14px;font-weight:700;color:#fbbf24;margin-top:2px">{{ week_start }} – {{ week_end }}</div>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- SCOPE NOTICE -->
  <tr>
    <td class="threshold-notice" style="background:#fef3c7;border-bottom:1px solid #fcd34d;padding:10px 32px;font-size:11px;color:#78350f;line-height:1.5">
      <strong>Scope:</strong> New records appearing in the registry between the prior-Friday and current-Friday snapshots. Issuance = Active or Retired status only. Retirements = all entries in the retired ledger. &nbsp;•&nbsp; <strong>Event-detail tables</strong> list transactions ≥ {{ ifm_threshold|thousands }} (IFM) or ≥ {{ nonifm_threshold|thousands }} (Non-IFM). Summary tables include all sizes.
    </td>
  </tr>

  <!-- "THIS WEEK" LABEL -->
  <tr>
    <td style="background:#fff;padding:14px 32px 4px;text-align:center">
      <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;color:#64748b;text-transform:uppercase">— This Week's Activity ({{ week_start }} – {{ week_end }}) —</div>
    </td>
  </tr>

  <!-- KPI STRIP -->
  <tr>
    <td style="padding:8px 0 0;background:#e2e8f0">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="kpi-strip" style="border-collapse:separate;border-spacing:1px 0">
        <tr>
          <td class="kpi-green" style="background:#fff;padding:14px 12px;text-align:center;border-left:3px solid #10b981;width:25%">
            <div style="font-size:9px;font-weight:600;letter-spacing:0.8px;color:#64748b;text-transform:uppercase">IFM Issued This Wk</div>
            <div style="font-size:17px;font-weight:800;color:#0f172a;margin-top:3px">{{ ifm_issued_total_wk|thousands }}</div>
            <div style="font-size:9px;color:#94a3b8;margin-top:2px">{{ ifm_issue_event_count }} event{% if ifm_issue_event_count != 1 %}s{% endif %}</div>
          </td>
          <td class="kpi-red" style="background:#fff;padding:14px 12px;text-align:center;border-left:3px solid #dc2626;width:25%">
            <div style="font-size:9px;font-weight:600;letter-spacing:0.8px;color:#64748b;text-transform:uppercase">IFM Retired This Wk</div>
            <div style="font-size:17px;font-weight:800;color:#0f172a;margin-top:3px">{{ ifm_retired_total_wk|thousands }}</div>
            <div style="font-size:9px;color:#94a3b8;margin-top:2px">{{ ifm_retire_event_count }} event{% if ifm_retire_event_count != 1 %}s{% endif %}</div>
          </td>
          <td class="kpi-green" style="background:#fff;padding:14px 12px;text-align:center;border-left:3px solid #10b981;width:25%">
            <div style="font-size:9px;font-weight:600;letter-spacing:0.8px;color:#64748b;text-transform:uppercase">Non-IFM Issued This Wk</div>
            <div style="font-size:17px;font-weight:800;color:#0f172a;margin-top:3px">{{ nonifm_issued_total_wk|thousands }}</div>
            <div style="font-size:9px;color:#94a3b8;margin-top:2px">{{ nonifm_issue_event_count }} event{% if nonifm_issue_event_count != 1 %}s{% endif %}</div>
          </td>
          <td class="kpi-red" style="background:#fff;padding:14px 12px;text-align:center;border-left:3px solid #dc2626;width:25%">
            <div style="font-size:9px;font-weight:600;letter-spacing:0.8px;color:#64748b;text-transform:uppercase">Non-IFM Retired This Wk</div>
            <div style="font-size:17px;font-weight:800;color:#0f172a;margin-top:3px">{{ nonifm_retired_total_wk|thousands }}</div>
            <div style="font-size:9px;color:#94a3b8;margin-top:2px">{{ nonifm_retire_event_count }} event{% if nonifm_retire_event_count != 1 %}s{% endif %}</div>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- NARRATIVE -->
  <tr>
    <td class="narrative" style="padding:20px 32px 4px;background:#fff">
      <div style="font-size:14px;font-weight:700;color:#0f172a;margin-bottom:8px">This week at a glance</div>
      <div class="narrative-body" style="font-size:12px;color:#334155;line-height:1.55">{{ narrative }}</div>
    </td>
  </tr>

  <!-- ACR IFM SECTION -->
  <tr>
    <td class="pad-mobile" style="padding:20px 32px 4px;background:#fff">
      <div class="section-header" style="background:#0f172a;color:#fbbf24;padding:10px 16px;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;border-radius:6px 6px 0 0">ACR IFM Activity</div>
    </td>
  </tr>

  <tr>
    <td class="pad-mobile" style="padding:0 32px;background:#fff">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-top:none;border-radius:0 0 6px 6px;font-size:11px;font-family:'SF Mono','Consolas',monospace">
        <thead>
          <tr style="background:#1e293b;color:#cbd5e1">
            <th style="padding:8px 12px;text-align:left;color:#f8fafc;font-weight:600">Category</th>
            <th style="padding:8px 10px;text-align:right;font-weight:500">This Wk</th>
            <th style="padding:8px 10px;text-align:right;font-weight:500;border-left:2px solid #334155">YTD {{ year_current }}</th>
            <th style="padding:8px 10px;text-align:right;font-weight:500">FY {{ year_prior }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for cat, wk, ytd, ly in ifm_rows_issued %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:6px 12px;font-weight:600;color:#334155">Issued — {{ cat }}</td>
            <td style="padding:6px 10px;text-align:right">{{ wk|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;border-left:2px solid #e2e8f0;font-weight:700">{{ ytd|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;color:#64748b">{{ ly|thousands }}</td>
          </tr>
          {%- endfor %}
          <tr style="background:#0f172a;color:#fbbf24;font-weight:700">
            <td style="padding:7px 12px;color:#fbbf24">Total IFM Issued</td>
            <td style="padding:7px 10px;text-align:right">{{ ifm_issued_totals[0]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right;border-left:2px solid #334155">{{ ifm_issued_totals[1]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right">{{ ifm_issued_totals[2]|thousands }}</td>
          </tr>
          {%- for cat, wk, ytd, ly in ifm_rows_retired %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:6px 12px;font-weight:600;color:#334155">Retired — {{ cat }}</td>
            <td style="padding:6px 10px;text-align:right">{{ wk|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;border-left:2px solid #e2e8f0;font-weight:700">{{ ytd|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;color:#64748b">{{ ly|thousands }}</td>
          </tr>
          {%- endfor %}
          <tr style="background:#0f172a;color:#fbbf24;font-weight:700">
            <td style="padding:7px 12px;color:#fbbf24">Total IFM Retired</td>
            <td style="padding:7px 10px;text-align:right">{{ ifm_retired_totals[0]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right;border-left:2px solid #334155">{{ ifm_retired_totals[1]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right">{{ ifm_retired_totals[2]|thousands }}</td>
          </tr>
        </tbody>
      </table>
    </td>
  </tr>

  <!-- IFM CHARTS -->
  <tr>
    <td class="pad-mobile" style="padding:16px 32px 4px;background:#fff">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="stack-mobile" style="vertical-align:top;padding-right:6px;width:50%">
            <div style="font-size:11px;font-weight:700;color:#0f172a;margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">IFM Static — Cum. Issued vs. Retired (YTD)</div>
            <div style="background:#fafbfc;border:1px solid #e2e8f0;border-radius:6px;padding:8px;text-align:center">
              <img class="chart-img" src="{{ chart_ifm_static }}" alt="IFM Static" style="width:100%;max-width:320px;height:auto;display:block;margin:0 auto"/>
            </div>
          </td>
          <td class="stack-mobile" style="vertical-align:top;padding-left:6px;width:50%">
            <div style="font-size:11px;font-weight:700;color:#0f172a;margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">IFM Dynamic — Cum. Issued vs. Retired (YTD)</div>
            <div style="background:#fafbfc;border:1px solid #e2e8f0;border-radius:6px;padding:8px;text-align:center">
              <img class="chart-img" src="{{ chart_ifm_dynamic }}" alt="IFM Dynamic" style="width:100%;max-width:320px;height:auto;display:block;margin:0 auto"/>
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- IFM TOP TABLES -->
  <tr>
    <td class="pad-mobile" style="padding:16px 32px 4px;background:#fff">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="stack-mobile" style="vertical-align:top;padding-right:8px;width:50%">
            <div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:8px">Top IFM Issuers — This Week</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-radius:6px;font-size:10px;font-family:'SF Mono','Consolas',monospace">
              <thead><tr style="background:#0f172a;color:#cbd5e1"><th style="padding:7px 8px;text-align:left;color:#f8fafc">Developer</th><th style="padding:7px 8px;text-align:right">Credits</th></tr></thead>
              <tbody>
                {%- for name, q in top_ifm_issuers %}
                <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}"><td style="padding:5px 8px;color:#334155;font-weight:600">{{ name }}</td><td style="padding:5px 8px;text-align:right">{{ q|thousands }}</td></tr>
                {%- endfor %}
              </tbody>
            </table>
          </td>
          <td class="stack-mobile" style="vertical-align:top;padding-left:8px;width:50%">
            <div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:8px">Top IFM Retirement Accounts — This Week</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-radius:6px;font-size:10px;font-family:'SF Mono','Consolas',monospace">
              <thead><tr style="background:#0f172a;color:#cbd5e1"><th style="padding:7px 8px;text-align:left;color:#f8fafc">On Behalf Of</th><th style="padding:7px 8px;text-align:right">Credits</th></tr></thead>
              <tbody>
                {%- for name, q in top_ifm_retirees %}
                <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}"><td style="padding:5px 8px;color:#334155;font-weight:600">{{ name }}</td><td style="padding:5px 8px;text-align:right">{{ q|thousands }}</td></tr>
                {%- endfor %}
              </tbody>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- IFM EVENTS >= threshold -->
  <tr>
    <td class="pad-mobile" style="padding:16px 32px 4px;background:#fff">
      <div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:8px">IFM Events ≥ {{ ifm_threshold|thousands }} This Week</div>
      {%- if ifm_issue_events or ifm_retire_events %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-radius:6px;font-size:10px;font-family:'SF Mono','Consolas',monospace">
        <thead><tr style="background:#0f172a;color:#cbd5e1"><th style="padding:7px 8px;text-align:left;color:#f8fafc">Date</th><th style="padding:7px 8px;text-align:left;color:#f8fafc">Type</th><th style="padding:7px 8px;text-align:left;color:#f8fafc">Project</th><th style="padding:7px 8px;text-align:left;color:#f8fafc">Developer / Account</th><th style="padding:7px 8px;text-align:right">Credits</th></tr></thead>
        <tbody>
          {%- for e in ifm_issue_events %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:5px 8px;color:#334155">{{ e.d }}</td>
            <td style="padding:5px 8px"><span style="background:#dcfce7;color:#166534;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:700">ISSUED</span></td>
            <td style="padding:5px 8px;color:#334155">{{ e.pid }} — {{ e.pn|default('', true) }}</td>
            <td style="padding:5px 8px;color:#334155">{{ e.dev|default('—', true) }}</td>
            <td style="padding:5px 8px;text-align:right;font-weight:700">{{ e.q|thousands }}</td>
          </tr>
          {%- endfor %}
          {%- for e in ifm_retire_events %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:5px 8px;color:#334155">{{ e.d }}</td>
            <td style="padding:5px 8px"><span style="background:#fee2e2;color:#991b1b;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:700">RETIRED</span></td>
            <td style="padding:5px 8px;color:#334155">{{ e.pid }} — {{ e.pn|default('', true) }}</td>
            <td style="padding:5px 8px;color:#334155">{{ e.b|default('—', true) }}</td>
            <td style="padding:5px 8px;text-align:right;font-weight:700">{{ e.q|thousands }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
      {%- else %}
      <div style="font-size:11px;color:#64748b;font-style:italic;padding:8px">No IFM events ≥ {{ ifm_threshold|thousands }} this week.</div>
      {%- endif %}
    </td>
  </tr>

  <!-- ACR NON-IFM SECTION -->
  <tr>
    <td class="pad-mobile" style="padding:28px 32px 4px;background:#fff">
      <div class="section-header" style="background:#0f172a;color:#fbbf24;padding:10px 16px;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;border-radius:6px 6px 0 0">ACR Non-IFM Activity</div>
    </td>
  </tr>

  <tr>
    <td class="pad-mobile" style="padding:0 32px;background:#fff">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-top:none;border-radius:0 0 6px 6px;font-size:11px;font-family:'SF Mono','Consolas',monospace">
        <thead>
          <tr style="background:#1e293b;color:#cbd5e1">
            <th style="padding:8px 12px;text-align:left;color:#f8fafc;font-weight:600">Methodology</th>
            <th style="padding:8px 10px;text-align:right;font-weight:500">This Wk</th>
            <th style="padding:8px 10px;text-align:right;font-weight:500;border-left:2px solid #334155">YTD {{ year_current }}</th>
            <th style="padding:8px 10px;text-align:right;font-weight:500">FY {{ year_prior }}</th>
          </tr>
        </thead>
        <tbody>
          <tr style="background:#f1f5f9"><td colspan="4" style="padding:6px 12px;font-size:10px;font-weight:700;color:#475569;letter-spacing:0.5px;text-transform:uppercase">Issuance</td></tr>
          {%- for meth, wk, ytd, ly in nonifm_issued_rows %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:6px 12px;font-weight:600;color:#334155">{{ meth }}</td>
            <td style="padding:6px 10px;text-align:right">{{ wk|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;border-left:2px solid #e2e8f0;font-weight:700">{{ ytd|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;color:#64748b">{{ ly|thousands }}</td>
          </tr>
          {%- endfor %}
          <tr style="background:#0f172a;color:#fbbf24;font-weight:700">
            <td style="padding:7px 12px;color:#fbbf24">Total Non-IFM Issued</td>
            <td style="padding:7px 10px;text-align:right">{{ nonifm_issued_totals[0]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right;border-left:2px solid #334155">{{ nonifm_issued_totals[1]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right">{{ nonifm_issued_totals[2]|thousands }}</td>
          </tr>
          <tr style="background:#f1f5f9"><td colspan="4" style="padding:6px 12px;font-size:10px;font-weight:700;color:#475569;letter-spacing:0.5px;text-transform:uppercase">Retirements</td></tr>
          {%- for meth, wk, ytd, ly in nonifm_retired_rows %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:6px 12px;font-weight:600;color:#334155">{{ meth }}</td>
            <td style="padding:6px 10px;text-align:right">{{ wk|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;border-left:2px solid #e2e8f0;font-weight:700">{{ ytd|thousands }}</td>
            <td style="padding:6px 10px;text-align:right;color:#64748b">{{ ly|thousands }}</td>
          </tr>
          {%- endfor %}
          <tr style="background:#0f172a;color:#fbbf24;font-weight:700">
            <td style="padding:7px 12px;color:#fbbf24">Total Non-IFM Retired</td>
            <td style="padding:7px 10px;text-align:right">{{ nonifm_retired_totals[0]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right;border-left:2px solid #334155">{{ nonifm_retired_totals[1]|thousands }}</td>
            <td style="padding:7px 10px;text-align:right">{{ nonifm_retired_totals[2]|thousands }}</td>
          </tr>
        </tbody>
      </table>
    </td>
  </tr>

  <!-- NON-IFM CHARTS -->
  <tr>
    <td class="pad-mobile" style="padding:16px 32px 4px;background:#fff">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="stack-mobile" style="vertical-align:top;padding-right:6px;width:50%">
            <div style="font-size:11px;font-weight:700;color:#0f172a;margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Non-IFM Issuance by Methodology — This Wk</div>
            <div style="background:#fafbfc;border:1px solid #e2e8f0;border-radius:6px;padding:8px;text-align:center">
              <img class="chart-img" src="{{ chart_nonifm_issuance }}" alt="Non-IFM Issuance" style="width:100%;max-width:320px;height:auto;display:block;margin:0 auto"/>
            </div>
          </td>
          <td class="stack-mobile" style="vertical-align:top;padding-left:6px;width:50%">
            <div style="font-size:11px;font-weight:700;color:#0f172a;margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Non-IFM Retirements by Methodology — This Wk</div>
            <div style="background:#fafbfc;border:1px solid #e2e8f0;border-radius:6px;padding:8px;text-align:center">
              <img class="chart-img" src="{{ chart_nonifm_retirements }}" alt="Non-IFM Retirements" style="width:100%;max-width:320px;height:auto;display:block;margin:0 auto"/>
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- NON-IFM TOP TABLES -->
  <tr>
    <td class="pad-mobile" style="padding:16px 32px 4px;background:#fff">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="stack-mobile" style="vertical-align:top;padding-right:8px;width:50%">
            <div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:8px">Top Non-IFM Issuers — This Week</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-radius:6px;font-size:10px;font-family:'SF Mono','Consolas',monospace">
              <thead><tr style="background:#0f172a;color:#cbd5e1"><th style="padding:7px 8px;text-align:left;color:#f8fafc">Developer</th><th style="padding:7px 8px;text-align:right">Credits</th></tr></thead>
              <tbody>
                {%- for name, q in top_nonifm_issuers %}
                <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}"><td style="padding:5px 8px;color:#334155;font-weight:600">{{ name }}</td><td style="padding:5px 8px;text-align:right">{{ q|thousands }}</td></tr>
                {%- endfor %}
              </tbody>
            </table>
          </td>
          <td class="stack-mobile" style="vertical-align:top;padding-left:8px;width:50%">
            <div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:8px">Top Non-IFM Retirement Accounts — This Week</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-radius:6px;font-size:10px;font-family:'SF Mono','Consolas',monospace">
              <thead><tr style="background:#0f172a;color:#cbd5e1"><th style="padding:7px 8px;text-align:left;color:#f8fafc">On Behalf Of</th><th style="padding:7px 8px;text-align:right">Credits</th></tr></thead>
              <tbody>
                {%- for name, q in top_nonifm_retirees %}
                <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}"><td style="padding:5px 8px;color:#334155;font-weight:600">{{ name }}</td><td style="padding:5px 8px;text-align:right">{{ q|thousands }}</td></tr>
                {%- endfor %}
              </tbody>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- NON-IFM EVENTS >= threshold -->
  <tr>
    <td class="pad-mobile" style="padding:16px 32px 4px;background:#fff">
      <div style="font-size:12px;font-weight:700;color:#0f172a;margin-bottom:8px">Non-IFM Events ≥ {{ nonifm_threshold|thousands }} This Week</div>
      {%- if nonifm_issue_events or nonifm_retire_events %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="data-table" style="border:1px solid #e2e8f0;border-radius:6px;font-size:10px;font-family:'SF Mono','Consolas',monospace">
        <thead><tr style="background:#0f172a;color:#cbd5e1"><th style="padding:7px 8px;text-align:left;color:#f8fafc">Date</th><th style="padding:7px 8px;text-align:left;color:#f8fafc">Type</th><th style="padding:7px 8px;text-align:left;color:#f8fafc">Methodology</th><th style="padding:7px 8px;text-align:left;color:#f8fafc">Project</th><th style="padding:7px 8px;text-align:left;color:#f8fafc">Developer / Account</th><th style="padding:7px 8px;text-align:right">Credits</th></tr></thead>
        <tbody>
          {%- for e in nonifm_issue_events %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:5px 8px;color:#334155">{{ e.d }}</td>
            <td style="padding:5px 8px"><span style="background:#dcfce7;color:#166534;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:700">ISSUED</span></td>
            <td style="padding:5px 8px;color:#334155">{{ e._methodology }}</td>
            <td style="padding:5px 8px;color:#334155">{{ e.pid }} — {{ e.pn|default('', true) }}</td>
            <td style="padding:5px 8px;color:#334155">{{ e.dev|default('—', true) }}</td>
            <td style="padding:5px 8px;text-align:right;font-weight:700">{{ e.q|thousands }}</td>
          </tr>
          {%- endfor %}
          {%- for e in nonifm_retire_events %}
          <tr style="background:{% if loop.index0 % 2 == 0 %}#f8fafc{% else %}#fff{% endif %}">
            <td style="padding:5px 8px;color:#334155">{{ e.d }}</td>
            <td style="padding:5px 8px"><span style="background:#fee2e2;color:#991b1b;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:700">RETIRED</span></td>
            <td style="padding:5px 8px;color:#334155">{{ e._methodology }}</td>
            <td style="padding:5px 8px;color:#334155">{{ e.pid }} — {{ e.pn|default('', true) }}</td>
            <td style="padding:5px 8px;color:#334155">{{ e.b|default('—', true) }}</td>
            <td style="padding:5px 8px;text-align:right;font-weight:700">{{ e.q|thousands }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
      {%- else %}
      <div style="font-size:11px;color:#64748b;font-style:italic;padding:8px">No Non-IFM events ≥ {{ nonifm_threshold|thousands }} this week.</div>
      {%- endif %}
    </td>
  </tr>

  <!-- FOOTER -->
  <tr>
    <td style="padding:24px 32px 20px;background:#f8fafc;border-top:1px solid #e2e8f0">
      <div style="text-align:center">
        <a href="{{ dashboard_url }}" style="display:inline-block;background:#0f172a;color:#fbbf24;padding:10px 20px;text-decoration:none;border-radius:5px;font-size:12px;font-weight:700;letter-spacing:0.5px">View Full Dashboard →</a>
      </div>
      <div style="text-align:center;font-size:10px;color:#94a3b8;margin-top:16px;line-height:1.6">
        Oak Hill Advisors — ACR IFM Registry Monitoring<br>
        Data sourced from ACR registry; weekly digest covers records newly appearing between prior-Friday and current-Friday snapshots.<br>
        Issuance: Active or Retired status only. Retirements: all. Thresholds apply to "Events ≥" tables only (IFM ≥ {{ ifm_threshold|thousands }} &nbsp;•&nbsp; Non-IFM ≥ {{ nonifm_threshold|thousands }}).
      </div>
    </td>
  </tr>

</table>

</body>
</html>
